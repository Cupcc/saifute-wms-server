# Saifute WMS backend environment template.
# For production deployment, copy this file to .env.prod and replace every
# placeholder value. Do not commit real credentials or secrets.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="mysql://wms_user:change-me@127.0.0.1:3306/saifute-wms?allowPublicKeyRetrieval=true"
LEGACY_DATABASE_URL="mysql://legacy_reader:change-me@127.0.0.1:3306/saifute"

# ---------------------------------------------------------------------------
# Runtime / HTTP
# ---------------------------------------------------------------------------
APP_NAME=saifute-wms-server
NODE_ENV=production
PORT=3000
API_GLOBAL_PREFIX=api
# Leave empty/false for direct access. Use 1 behind one trusted reverse proxy,
# or set trusted proxy CIDRs according to the deployment ingress.
HTTP_TRUST_PROXY=
# Path to the built web SPA served by the same process (relative to app root).
WEB_DIST_PATH=web/dist

# ---------------------------------------------------------------------------
# API docs
# ---------------------------------------------------------------------------
SWAGGER_ENABLED=false
SWAGGER_TITLE=saifute-wms-server API
SWAGGER_DESCRIPTION=Saifute WMS API documentation
SWAGGER_VERSION=0.1.0
SWAGGER_PATH=docs
SWAGGER_JSON_PATH=docs-json

# ---------------------------------------------------------------------------
# Auth / sessions
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-random-32-byte-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-different-random-32-byte-refresh-token-secret
JWT_EXPIRES_IN_SECONDS=3600
SESSION_TTL_SECONDS=604800
SESSION_MAX_TTL_SECONDS=2592000
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000
SESSION_REFRESH_THRESHOLD_SECONDS=1200
CAPTCHA_TTL_SECONDS=300
CAPTCHA_ENABLED=true
PASSWORD_MAX_RETRIES=5
PASSWORD_LOCK_MINUTES=15
AUTH_IP_BLACKLIST=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
FILE_STORAGE_ROOT_PATH=storage
FILE_STORAGE_PUBLIC_PREFIX=/profile
FILE_STORAGE_MAX_SIZE_BYTES=5242880
FILE_STORAGE_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.zip,.rar
# Legacy alias accepted by the app if FILE_STORAGE_ROOT_PATH is absent:
# UPLOAD_ROOT_PATH=storage

# ---------------------------------------------------------------------------
# Business time / scheduler
# ---------------------------------------------------------------------------
BUSINESS_TIMEZONE=Asia/Shanghai
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Shanghai
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_DIR=storage/database-backups
DATABASE_BACKUP_COMMAND=mysqldump
DATABASE_BACKUP_RETENTION_FULL_COUNT=2

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs

# ---------------------------------------------------------------------------
# AI assistant
# ---------------------------------------------------------------------------
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_MODEL=gpt-4.1-mini
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_TIMEOUT_MS=15000
